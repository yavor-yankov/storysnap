{
  "permissions": {
    "allow": [
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__list_directory",
      "Bash(npx:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(code .)",
      "Bash(ls:*)",
      "Bash(curl -s https://who.is/whois/pixtales.ai)",
      "Bash(curl -s https://who.is/whois/pixtales.com)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
