# Database (SQLite - local, no setup needed)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# GitHub OAuth (optional - for social login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AI Image Generation (mock mode by default)
# Set to "replicate" to use real AI, leave empty for mock
AI_IMAGE_PROVIDER="mock"
REPLICATE_API_TOKEN=""

# Claude API (for story generation)
ANTHROPIC_API_KEY=""

# Resend (for emails - optional in dev)
RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PixTales"