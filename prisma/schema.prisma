generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  books    Book[]
  orders   Order[]
  credits  Int       @default(3) // Free credits to start
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== CORE ====================

model Book {
  id          String   @id @default(cuid())
  title       String
  userId      String
  status      String   @default("draft") // draft, generating, complete, failed
  artStyle    String   // comic, anime, watercolor, manga, storybook, pop-art
  portraitUrl String   // uploaded portrait path
  coverUrl    String?  // generated cover image path
  pdfUrl      String?  // generated PDF path
  pageCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages  BookPage[]
  order  Order?
}

model BookPage {
  id        String @id @default(cuid())
  bookId    String
  pageNum   Int
  imageUrl  String?  // generated illustration path
  text      String   // story text for this page
  prompt    String?  // AI prompt used for image generation

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, pageNum])
}

// ==================== BILLING ====================

model Order {
  id               String   @id @default(cuid())
  userId           String
  bookId           String   @unique
  amount           Int      // in cents
  currency         String   @default("usd")
  status           String   @default("pending") // pending, paid, failed, refunded
  stripePaymentId  String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}